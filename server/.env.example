
# ==============================
# Mi MedCare Server
# ==============================
APP_PORT="4000"
APP_ENDPOINT="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
CLIENT_ENDPOINT="http://localhost:3000"
ADMIN_ENDPOINT="http://localhost:3001"

# ==============================
# Database
# ==============================
# Example: postgresql://postgres:password@localhost:5432/mi-medcare
DB_URI="postgresql://postgres:password@localhost:5432/mi-medcare"

# ==============================
# Media Storage
# ==============================
CLOUDINARY_ROOT_FOLDER="mi-medcare"
CLOUDINARY_URL="cloudinary://your-cloudinary-api-key:your-cloudinary-api-secret@your-cloud-name"

# ==============================
# OTP and Auth
# ==============================
OTP_EXP="15m"
ACCESS_TOKEN_EXP="15m"
REFRESH_TOKEN_EXP="7d"
JWT_ACCESS_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"

# ==============================
# OAuth Providers
# ==============================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=""

# ==============================
# Email Delivery
# ==============================
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="replace-with-your-smtp-password"

# ==============================
# SMS / WhatsApp (Twilio)
# ==============================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_WHATSAPP_NUMBER=""

# ==============================
# GHL
# ==============================
GHL_API_TOKEN=""
GHL_LOCATION_ID=""

# ==============================
# External APIs
# ==============================
IP_STACK_API_KEY=""

# ==============================
# Admin Bootstrap
# ==============================
ADMIN_NAME="Mi MedCare Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"
