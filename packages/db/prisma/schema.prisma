generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum ThemeMode {
  light
  dark
  system
}

enum UserRole {
  admin
  author
}

enum UserStatus {
  active
  suspended
}

enum OtpPurpose {
  setPassword
  resetPassword
  updatePassword
  verifyEmail
  updateEmail
  enableMfa
  disableMfa
  updateMfa
  verifyMfa
}

enum OtpType {
  numericCode
  secureToken
}

enum MfaMethod {
  email
  authApp
}

enum SessionStatus {
  active
  revoked
  expired
}

enum NotificationChannel {
  push
  email
}

enum PushProvider {
  fcm
  expo
}

enum NotificationPurpose {
  signUp
  signIn
  verifyMfa
  updateMfa
  updatePassword
  verifyEmail
  updateEmail

  userStatus

  newsletter
  securityAlert
  contactMessage
  consultationRequest
}

enum NotificationStatus {
  pending
  partial
  sent
  failed
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  statusChange
}

enum MediaVisibility {
  private
  public
}

enum MediaType {
  avatar
  logo
  post
  category
  other
}

enum PostStatus {
  draft
  published
}

enum PracticeType {
  privatePractice
  groupPractice
  hospital
  clinic
  urgentCare
  specialtyClinic
  other
}

enum ConsultationRequestStatus {
  new
  contacted
  qualified
  closed
}

enum MonthlyClaimsRange {
  range_0_250
  range_251_1000
  range_1001_3000
  range_3000_plus
}

enum ContactMessageStatus {
  pending
  viewed
  replied
}

enum ContactTimePreference {
  morning
  afternoon
  evening
  anytime
}

//
// AUTH MODELS
//

model User {
  // Core fields
  id          String  @id @default(ulid())
  firstName   String
  lastName    String?
  displayName String
  password    String? @db.VarChar(255)

  avatarId String?
  avatar   Media?  @relation("UserAvatars", fields: [avatarId], references: [id])

  // Contact info
  email           String? @unique @db.VarChar(255)
  isEmailVerified Boolean @default(false)

  role   UserRole
  status UserStatus @default(active)

  preferredTheme    ThemeMode @default(system)
  pushNotifications Boolean   @default(false)

  preferredMfa MfaMethod?

  loginAlerts Boolean   @default(true)
  lastLoginAt DateTime?

  // Meta
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  otps          Otp[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]

  posts  Post[]
  medias Media[] @relation("UserUploads")

  // Indexes
  @@index([status])
  @@index([role])
  @@index([email, isEmailVerified])
  @@index([deletedAt])
}

model Session {
  id String @id @default(ulid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  status           SessionStatus @default(active)

  ip       String
  location String
  isp      String?
  timezone String

  deviceId   String
  deviceType String
  deviceInfo String

  isTrusted  Boolean   @default(false)
  lastSeenAt DateTime?

  pushProvider PushProvider?
  pushToken    String?

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@unique([userId, deviceId])
  @@index([expiresAt])
  @@index([userId, status])
  @@index([expiresAt, status])
}

model Otp {
  id        String     @id @default(ulid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   OtpPurpose
  type      OtpType    @default(numericCode)
  secret    String
  meta      Json?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, purpose])
  @@index([expiresAt])
}

model Notification {
  id String @id @default(ulid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  message   String
  recipient String
  meta      Json?

  purpose  NotificationPurpose
  channels NotificationChannel[]
  status   NotificationStatus    @default(pending)

  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, readAt])
}

model Media {
  id String @id @default(ulid())

  uploadedById String
  uploadedBy   User   @relation("UserUploads", fields: [uploadedById], references: [id])

  publicId     String @unique
  url          String @unique
  mimeType     String
  resourceType String
  size         Int
  hash         String @unique

  name       String
  altText    String?
  type       MediaType
  visibility MediaVisibility @default(private)
  notes      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users            User[]            @relation("UserAvatars")
  posts            Post[]            @relation("PostCover")
  categories       Category[]        @relation("CategoryCover")
  businessLogos    BusinessProfile[] @relation("BusinessProfileLogo")
  businessCovers   BusinessProfile[] @relation("BusinessProfileCoverImage")
  businessFavIcons BusinessProfile[] @relation("BusinessProfileFavicon")

  @@index([type])
  @@index([name])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([deletedAt])
}

//
// SERVICES
//

model Post {
  id String @id @default(ulid())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  title   String
  slug    String @unique
  excerpt String
  content String @db.Text

  coverId String?
  cover   Media?  @relation("PostCover", fields: [coverId], references: [id])

  tags Tag[]

  status      PostStatus @default(draft)
  publishedAt DateTime?

  metaTitle       String?
  metaDescription String?

  viewsCount Int        @default(0)
  postViews  PostView[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([viewsCount])
  @@index([title])
  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
}

model PostView {
  id String @id @default(ulid())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  trafficSourceId String?
  trafficSource   TrafficSource? @relation(fields: [trafficSourceId], references: [id])

  visitorKey String   @db.VarChar(128)
  viewedOn   DateTime @db.Date
  viewedAt   DateTime @default(now())

  @@unique([postId, visitorKey, viewedOn])
  @@index([postId])
  @@index([viewedAt])
  @@index([postId, viewedAt])
}

model Category {
  id          String  @id @default(ulid())
  name        String  @unique
  slug        String  @unique
  description String?

  coverId String?
  cover   Media?  @relation("CategoryCover", fields: [coverId], references: [id])

  parentId String?
  parent   Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)

  children Category[] @relation("CategoryHierarchy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  posts Post[]

  @@index([name])
  @@index([parentId])
  @@index([slug])
  @@index([createdAt])
  @@index([deletedAt])
}

model Tag {
  id   String @id @default(ulid())
  name String @unique
  slug String @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  posts Post[]

  @@index([name])
  @@index([slug])
  @@index([createdAt])
  @@index([deletedAt])
}

//
// SYSTEM
//

model AuditLog {
  id String @id @default(ulid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action AuditAction

  entityType String
  entityId   String

  meta Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ContactMessage {
  id String @id @default(cuid())

  trafficSourceId String?
  trafficSource   TrafficSource? @relation(fields: [trafficSourceId], references: [id])

  fullName        String
  practiceName    String?
  email           String
  phone           String
  practiceType    PracticeType?
  bestContactTime ContactTimePreference?
  message         String

  status ContactMessageStatus @default(pending)
  notes  String?

  viewedAt  DateTime?
  repliedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([createdAt])
  @@index([status])
  @@index([email])
}

model ConsultationRequest {
  id String @id @default(cuid())

  trafficSourceId String?
  trafficSource   TrafficSource? @relation(fields: [trafficSourceId], references: [id])

  fullName      String
  practiceName  String
  email         String
  phone         String
  practiceType  PracticeType?
  monthlyClaims MonthlyClaimsRange?
  message       String

  status ConsultationRequestStatus @default(new)
  notes  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([createdAt])
  @@index([status])
  @@index([email])
  @@index([phone])
}

model NewsletterSubscriber {
  id String @id @default(ulid())

  trafficSourceId String?
  trafficSource   TrafficSource? @relation(fields: [trafficSourceId], references: [id])

  name  String
  email String @unique @db.VarChar(255)

  isActive Boolean @default(true)

  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([createdAt])
  @@index([isActive])
}

model TrafficSource {
  id String @id @default(ulid())

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?

  referrer    String?
  landingPage String?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  postViews            PostView[]
  contactMessages      ContactMessage[]
  consultationRequests ConsultationRequest[]
  newsletterSubs       NewsletterSubscriber[]
}

model BusinessPhone {
  id    String @id @default(ulid())
  label String
  value String @db.VarChar(20)

  whatsappProfile BusinessProfile? @relation("BusinessProfileWhatsapp")

  phoneProfileId String?
  phoneProfile   BusinessProfile? @relation("BusinessProfilePhones", fields: [phoneProfileId], references: [id], onDelete: Cascade)

  faxProfileId String?
  faxProfile   BusinessProfile? @relation("BusinessProfileFax", fields: [faxProfileId], references: [id], onDelete: Cascade)
}

model BusinessAddress {
  id      String @id @default(ulid())
  label   String
  line1   String
  city    String
  state   String
  zip     String
  country String

  businessProfileId String?
  businessProfile   BusinessProfile? @relation("BusinessProfileAddresses", fields: [businessProfileId], references: [id], onDelete: Cascade)
}

model BusinessProfile {
  id String @id @default(ulid())

  name        String
  legalName   String
  description String

  faviconId String
  favicon   Media  @relation("BusinessProfileFavicon", fields: [faviconId], references: [id])

  logoId String
  logo   Media  @relation("BusinessProfileLogo", fields: [logoId], references: [id])

  coverId String?
  cover   Media?  @relation("BusinessProfileCoverImage", fields: [coverId], references: [id])

  email String @db.VarChar(255)

  whatsappId String        @unique
  whatsapp   BusinessPhone @relation("BusinessProfileWhatsapp", fields: [whatsappId], references: [id])

  website   String
  facebook  String
  instagram String
  twitter   String
  linkedin  String

  fax       BusinessPhone[]   @relation("BusinessProfileFax")
  phones    BusinessPhone[]   @relation("BusinessProfilePhones")
  addresses BusinessAddress[] @relation("BusinessProfileAddresses")

  officeHoursDays String?
  officeHoursTime String?

  metaTitle       String
  metaDescription String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
